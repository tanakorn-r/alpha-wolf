{
  "name": "alpha-wolf",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:api & npm run dev:web",
    "build": "nx build web",
    "dev:web": "nx serve web",
