{
  "name": "alpha-wolf",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx run-many --target=serve --projects=api,web --parallel=2",
    "build": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx run-many --target=build --projects=api,web --parallel=2",
    "dev:web": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx serve web",
    "dev:api": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx serve api",
    "dev:go-api": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx serve go-api",
    "build:web": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx build web",
    "build:web:static": "vite build apps/web --outDir ../../dist/apps/web --emptyOutDir",
    "build:api": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx build api",
    "format": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx format:write"
  },
  "devDependencies": {
    "@nx/react": "^19.6.4",
    "@nx/vite": "^19.6.4",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.10.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.5.0",
    "nx": "^19.6.4",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.8"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.8.1",
    "zustand": "^5.0.2"
  }
}
