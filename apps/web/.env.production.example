# Copy this to apps/web/.env.production before a production / native build.
#
# The packaged mobile app and any static production deploy have NO Vite dev
# proxy, so relative "/api" calls will not reach the backend. Point this at
# your hosted API base, INCLUDING the /api suffix:
#
#   VITE_API_BASE=https://your-api-host.example.com/api
#
# Note: api.ts uses `import.meta.env.VITE_API_BASE ?? "/api"`, so an EMPTY value
# counts as "set" and breaks every fetch. Either give a real URL or delete the
# line entirely (the app then falls back to "/api", i.e. dev-proxy behavior,
# which will NOT work on a device).
VITE_API_BASE=https://your-api-host.example.com/api

# Public browser configuration from Firebase Console > Project settings >
# Your apps > Web app > SDK setup and configuration. Use a separate Firebase
# project or Web app for preview/staging when you want isolated analytics.
VITE_FIREBASE_API_KEY=AIzaSyBbTMdf0jRdv-Jx_Ez9IoErkYRooLIAoPE
VITE_FIREBASE_AUTH_DOMAIN=alpha-wolf-c16d8.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=alpha-wolf-c16d8
VITE_FIREBASE_STORAGE_BUCKET=alpha-wolf-c16d8.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=135073173307
VITE_FIREBASE_APP_ID=1:135073173307:web:fa534ec49b783969f7711e
VITE_FIREBASE_MEASUREMENT_ID=G-Z4FZNH88TW
