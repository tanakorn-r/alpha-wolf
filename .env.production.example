OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.5
GOOGLE_CLIENT_ID=your_google_web_client_id
STRIPE_SECRET_KEY=your_rotated_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret
APP_URL=https://your-frontend-host.example.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
CORS_ORIGINS=https://your-frontend-domain.example
LIBSQL_DATABASE_URL=libsql://alpha-wolf-marjod.aws-ap-northeast-1.turso.io
LIBSQL_AUTH_TOKEN=your_turso_auth_token
# Server-only secret for GET /api/telemetry/summary. Generate a long random
# value and never expose it through a VITE_* variable or frontend code.
TELEMETRY_ADMIN_TOKEN=your_long_random_admin_token
# "Pro free for everyone" promo — every account (signed-in or guest) gets Hunt AI Pro at no
# cost while this is true. Set to false and restart the API to end the promo; there is no
# automatic expiry. Defaults to true when unset.
PREMIUM_PROMO_ENABLED=true
